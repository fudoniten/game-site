---
import { videoId } from '../lib/youtube';
import site from '../data/site.json';

const videos = (site.youtube.videos ?? [])
  .map((url) => ({ url, id: videoId(url) }))
  .filter((video): video is { url: string; id: string } => Boolean(video.id));
---

{
  videos.length > 0 ? (
    <div class="youtube-grid">
      {videos.map((video) => (
        <iframe
          class="youtube-embed"
          src={`https://www.youtube-nocookie.com/embed/${video.id}`}
          title="Jasper's video"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        />
      ))}
    </div>
  ) : (
    <div class="youtube-empty">
      <p>
        No videos are configured yet. Add video URLs to <code>youtube.videos</code> in{' '}
        <code>src/data/site.json</code> to show them here.
      </p>
      {site.youtube.channelUrl && (
        <a class="button secondary" href={site.youtube.channelUrl} target="_blank" rel="noopener noreferrer">
          Visit the channel
        </a>
      )}
    </div>
  )
}
